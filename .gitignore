# ==========================================
# Fullstack Project .gitignore
# Covers .NET Core, Angular, Node.js, SQLite
# ==========================================

# =========================
# 1. Frontend (Angular/Node)
# =========================
# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Dependencies
node_modules/
aifitapp-frontend/node_modules/

# Angular build outputs
dist/
aifitapp-frontend/dist/
tmp/
out-tsc/
bazel-out/

# Angular cache
.angular/
aifitapp-frontend/.angular/

# =========================
# 2. Backend (.NET Core / C#)
# =========================
# Build results
[Bb]in/
[Oo]bj/
AIFitApp/bin/
AIFitApp/obj/

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific configuration (Local Development)
appsettings.Development.json
appsettings.*.json

# =========================
# 3. Environment & Secrets
# =========================
.env
.env.*
!.env.example

# =========================
# 4. Databases (SQLite)
# =========================
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3
aifitapp.db
# (Ignore the database files completely so you don't commit real local user data)

# =========================
# 5. IDEs and OS Folders
# =========================
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.idea/
.vs/
*.swp
.DS_Store
Thumbs.db
