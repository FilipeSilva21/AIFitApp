# ==========================================
# Fullstack Project .gitignore (Universal)
# Covers .NET Core, Angular, Node.js, SQLite
# ==========================================

# =========================
# 1. Frontend (Angular/Node)
# =========================
# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
libpeerconnection.log
testem.log

# Dependencies
node_modules/
**/node_modules/

# Angular build outputs
dist/
**/dist/
tmp/
**/tmp/
out-tsc/
**/out-tsc/
bazel-out/
**/bazel-out/
coverage/
/__screenshots__/

# Angular cache & Misc
.angular/
**/.angular/
.sass-cache/
.history/*
connect.lock
typings/

# =========================
# 2. Backend (.NET Core / C#)
# =========================
# Build results
[Bb]in/
**/[Bb]in/
[Oo]bj/
**/[Oo]bj/

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific configuration (Local Development)
appsettings.Development.json
appsettings.*.json

# =========================
# 3. Environment & Secrets
# =========================
.env
.env.*
!.env.example

# =========================
# 4. Databases (SQLite)
# =========================
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3
aifitapp.db
# (Ignore the database files completely so you don't commit real local user data)

# =========================
# 5. IDEs and OS Folders
# =========================
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/mcp.json
.idea/
.vs/
.project
.classpath
.c9/
.settings/
*.swp
*.launch
*.sublime-workspace
.DS_Store
Thumbs.db
